# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
LANDING_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex
JWT_EXPIRES_IN=7d

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Add authorised redirect URIs: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ─── Gmail SMTP ───────────────────────────────────────────
# Use a Gmail App Password (not your account password)
# https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=onlyStuff <your_gmail@gmail.com>

# ─── Google Drive (image storage) ─────────────────────────
# No JSON key files needed — everything lives in env vars.
#
# 1. Create a folder in Google Drive and share it with your Gmail.
# 2. Copy the folder ID from the URL: drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=replace_with_drive_folder_id

# 3. Run once to get your refresh token:
#    node get-drive-token.js
#    Paste the printed token below. Keep this local — do NOT commit.
GOOGLE_DRIVE_REFRESH_TOKEN=replace_with_oauth_refresh_token

# GCP project (for reference — no service account JSON file needed)
GOOGLE_PROJECT_ID=replace_with_gcp_project_id

# ─── Maps ─────────────────────────────────────────────────
# Frontend uses OpenStreetMap via Leaflet — no key needed
# Backend geocoding uses Nominatim (OSM) — no key needed
# Optional: GOOGLE_MAPS_API_KEY=your_key_here  (if switching from OSM later)

# ─── Delivery Partners (add keys as you onboard them) ─────
PORTER_API_KEY=replace_when_available
DUNZO_API_KEY=replace_when_available
RAPIDO_API_KEY=replace_when_available
SWIGGY_GENIE_API_KEY=replace_when_available
